# LLM provider — follows litellm format: "provider/model"
# Examples:
#   openai/gpt-4o-mini
#   anthropic/claude-3-haiku-20240307
#   groq/llama-3.1-8b-instant
#   ollama/llama3.1
LLM_PROVIDER=openai/gpt-4o-mini
LLM_API_TOKEN=your-api-key-here

# Optional: custom base URL (for proxies, local servers, etc.)
# LLM_BASE_URL=http://localhost:11434

CACHE_TTL=3600
